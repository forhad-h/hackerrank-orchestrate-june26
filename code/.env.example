# ──────────────────────────────────────────────────────────────────────
# Required Environment Variables
# ──────────────────────────────────────────────────────────────────────

# OpenRouter API key — all LLM/VLM models are accessed via OpenRouter.
# Models used: gemini-2.5-flash, gemini-2.5-pro, gpt-4o, gpt-4o-mini,
#              claude-3.5-haiku, claude-sonnet-4-5
# Sign up at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────
# Optional Environment Variables
# ──────────────────────────────────────────────────────────────────────

# Override the default dataset directory.
# Defaults to <repo_root>/dataset/ if not set.
# Can be an absolute path or a path relative to the repo root.
# DATASET_DIR=/absolute/path/to/dataset

# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────
